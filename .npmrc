# Security: block all lifecycle scripts (preinstall/postinstall/install)
# To allow scripts for a trusted package: npm rebuild <package-name>
ignore-scripts=true

# Auto-run npm audit on every install
audit=true
audit-level=high

# Pin exact versions instead of semver ranges
save-exact=true

# Always maintain lockfile
package-lock=true

# Reduce noise so real warnings stand out
fund=false
